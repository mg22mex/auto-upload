# Copy to .env for local runs. Mirror these as GitHub Secrets for the self-hosted runner.

AUTOSELL_BASE_URL=https://www.autosell.mx
SYNC_TIMEZONE=America/Chihuahua

# Phase 0–1: inventory scrape + diff (DRY_RUN=true skips Facebook actions)
DRY_RUN=true

# Phase 2: set false on fb-worker after manual post tests pass
# DRY_RUN=false

MAX_POSTS_PER_ACCOUNT_PER_RUN=10
FB_ACTION_DELAY_MIN_SEC=60
FB_ACTION_DELAY_MAX_SEC=120
REMOVAL_ACTION=mark_sold

DB_PATH=data/sync.db
SNAPSHOT_DIR=data/snapshots

# CI split (matches .github/workflows/sync.yml):
#   python run_sync.py --scrape-only --output data/catalog_latest.json
#   python run_sync.py --from-snapshot data/catalog_latest.json

# Optional alerts when sync fails (Telegram)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
